Host github.com
ForwardAgent no

Host *
AddKeysToAgent yes
ControlMaster auto
{{- if eq .chezmoi.os "linux" }}
ControlPath ${XDG_RUNTIME_DIR}/.ssh_%C
{{- else if eq .chezmoi.os "darwin" }}
ControlPath /tmp/.ssh_%C
{{- end }}
ControlPersist 1800
ForwardAgent yes
ServerAliveInterval 60
StrictHostKeychecking accept-new
